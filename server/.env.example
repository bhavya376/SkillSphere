PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# Google OAuth Configuration (Obtain from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Hugging Face AI Matching Integration (Obtain from HF Account settings)
HUGGINGFACE_API_TOKEN=your_huggingface_api_token

# Razorpay Payment Gateway Integration (Obtain from Razorpay Dashboard settings)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret